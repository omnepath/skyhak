{
  "name": "skyhak",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "asbuild": "asc wasm/assembly/index.ts --outFile wasm/build/module.wasm --textFile wasm/build/module.wat --optimize && cp wasm/build/module.wasm public/module.wasm",
    "prebuild": "npm run asbuild"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tsconfig/svelte": "^5.0.0",
    "assemblyscript": "^0.27.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-wasm": "^3.4.0",
    "vitest": "^3.0.0"
  }
}
